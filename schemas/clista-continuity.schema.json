{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clista.local/schemas/clista-continuity.schema.json",
  "title": "ClisTa Continuity Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "packet_type",
    "protocol_version",
    "schema_version",
    "theorem",
    "hard_law",
    "clista_protocol_version",
    "source_thread_id",
    "event_log_hash",
    "projection_hash",
    "state_hash",
    "capability_set",
    "integrity_verified",
    "strict_integrity_verified",
    "verification_mode",
    "resume_status",
    "exported_at",
    "integrity",
    "verification_state",
    "source_events",
    "continuity_state"
  ],
  "properties": {
    "protocol": {
      "const": "clista"
    },
    "packet_type": {
      "const": "continuity"
    },
    "protocol_version": {
      "const": "0.14.0"
    },
    "schema_version": {
      "const": "clista.continuity.packet.v0"
    },
    "theorem": {
      "const": "reasoning_continuity = resume(project(event_log), verification_state)"
    },
    "hard_law": {
      "const": "context transfer != memory trust"
    },
    "clista_protocol_version": {
      "const": "clista.protocol.v0"
    },
    "source_thread_id": {
      "$ref": "#/$defs/id"
    },
    "event_log_hash": {
      "$ref": "#/$defs/hash"
    },
    "projection_hash": {
      "$ref": "#/$defs/hash"
    },
    "state_hash": {
      "$ref": "#/$defs/hash"
    },
    "capability_set": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "amendments"
      }
    },
    "integrity_verified": {
      "const": true
    },
    "strict_integrity_verified": {
      "type": "boolean"
    },
    "verification_mode": {
      "enum": [
        "strict",
        "compatibility"
      ]
    },
    "resume_status": {
      "enum": [
        "verified",
        "degraded",
        "rejected"
      ]
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "integrity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "valid",
        "eventCount",
        "headHash"
      ],
      "properties": {
        "schema": {
          "const": "clista.integrity.v0"
        },
        "valid": {
          "const": true
        },
        "eventCount": {
          "type": "integer",
          "minimum": 1
        },
        "headHash": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "verification_state": {
      "$ref": "#/$defs/verificationState"
    },
    "source_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "continuity_state": {
      "$ref": "#/$defs/continuityState"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{3}_[a-zA-Z0-9][a-zA-Z0-9_-]*$"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "continuityState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission",
        "continuity_claim",
        "theorem",
        "hard_law",
        "resume_status",
        "capability_set",
        "source_thread_id",
        "current_question",
        "current_request",
        "current_decision",
        "assumptions",
        "active_assumptions",
        "claims",
        "accepted_claims",
        "open_objections",
        "governance_status",
        "outcome_state",
        "fork_lineage",
        "merge_state",
        "attribution_state",
        "provenance_state",
        "learning_state",
        "adaptation_state",
        "amendment_state",
        "verification_status",
        "integrity_state",
        "status",
        "next_action"
      ],
      "properties": {
        "mission": {
          "const": "Conversation is input. Reasoning state is output."
        },
        "continuity_claim": {
          "const": "Projected reasoning state is continuity."
        },
        "theorem": {
          "const": "reasoning_continuity = resume(project(event_log), verification_state)"
        },
        "hard_law": {
          "const": "context transfer != memory trust"
        },
        "resume_status": {
          "enum": [
            "verified",
            "degraded",
            "rejected"
          ]
        },
        "capability_set": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_thread_id": {
          "$ref": "#/$defs/id"
        },
        "current_question": {
          "type": "string"
        },
        "current_request": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "current_decision": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "assumptions": {
          "$ref": "#/$defs/objectArray"
        },
        "active_assumptions": {
          "$ref": "#/$defs/objectArray"
        },
        "claims": {
          "$ref": "#/$defs/objectArray"
        },
        "accepted_claims": {
          "$ref": "#/$defs/objectArray"
        },
        "open_objections": {
          "$ref": "#/$defs/objectArray"
        },
        "governance_status": {
          "type": "object",
          "additionalProperties": true
        },
        "outcome_state": {
          "type": "object",
          "additionalProperties": true
        },
        "fork_lineage": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "merge_state": {
          "type": "object",
          "additionalProperties": true
        },
        "attribution_state": {
          "type": "object",
          "additionalProperties": true
        },
        "provenance_state": {
          "type": "object",
          "additionalProperties": true
        },
        "learning_state": {
          "type": "object",
          "additionalProperties": true
        },
        "adaptation_state": {
          "type": "object",
          "additionalProperties": true
        },
        "amendment_state": {
          "type": "object",
          "additionalProperties": true
        },
        "verification_status": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "status",
            "verification_mode",
            "required_layers",
            "transcript_replay",
            "memory_trust"
          ],
          "properties": {
            "status": {
              "enum": [
                "verified",
                "degraded",
                "rejected"
              ]
            },
            "verification_mode": {
              "enum": [
                "strict",
                "compatibility"
              ]
            },
            "required_layers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "transcript_replay": {
              "const": false
            },
            "memory_trust": {
              "const": false
            }
          }
        },
        "integrity_state": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "event_count",
            "event_log_hash",
            "head_hash",
            "integrity_verified",
            "strict_integrity_verified",
            "verification_mode"
          ],
          "properties": {
            "event_count": {
              "type": "integer",
              "minimum": 1
            },
            "event_log_hash": {
              "$ref": "#/$defs/hash"
            },
            "head_hash": {
              "$ref": "#/$defs/hash"
            },
            "integrity_verified": {
              "const": true
            },
            "strict_integrity_verified": {
              "type": "boolean"
            },
            "verification_mode": {
              "enum": [
                "strict",
                "compatibility"
              ]
            }
          }
        },
        "status": {
          "type": "string"
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "objectArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "verificationState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "theorem",
        "hardLaw",
        "status",
        "clistaProtocolVersion",
        "continuityProtocolVersion",
        "capabilitySet",
        "requiredLayers",
        "verificationMode",
        "eventLogHash",
        "projectionHash",
        "stateHash",
        "validity",
        "integrity",
        "attributionValidationStatus",
        "provenanceValidationStatus",
        "learningValidationStatus",
        "adaptationValidationStatus",
        "amendmentValidationStatus",
        "transcriptReplay",
        "memoryTrust",
        "authorityCreated",
        "governanceMutation",
        "amendmentApproval",
        "importedStateMutation"
      ],
      "properties": {
        "schema": {
          "const": "clista.continuity.verification_state.v0"
        },
        "theorem": {
          "const": "reasoning_continuity = resume(project(event_log), verification_state)"
        },
        "hardLaw": {
          "const": "context transfer != memory trust"
        },
        "status": {
          "enum": [
            "verified",
            "degraded",
            "rejected"
          ]
        },
        "continuityProtocolVersion": {
          "const": "0.14.0"
        },
        "verificationMode": {
          "enum": [
            "strict",
            "compatibility"
          ]
        },
        "eventLogHash": {
          "$ref": "#/$defs/hash"
        },
        "projectionHash": {
          "$ref": "#/$defs/hash"
        },
        "stateHash": {
          "$ref": "#/$defs/hash"
        },
        "transcriptReplay": {
          "const": false
        },
        "memoryTrust": {
          "const": false
        },
        "authorityCreated": {
          "const": false
        },
        "governanceMutation": {
          "const": false
        },
        "amendmentApproval": {
          "const": false
        },
        "importedStateMutation": {
          "const": false
        }
      }
    }
  }
}
