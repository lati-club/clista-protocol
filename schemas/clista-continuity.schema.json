{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clista.local/schemas/clista-continuity.schema.json",
  "title": "ClisTa Continuity Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "packet_type",
    "protocol_version",
    "schema_version",
    "clista_protocol_version",
    "source_thread_id",
    "event_log_hash",
    "projection_hash",
    "state_hash",
    "integrity_verified",
    "strict_integrity_verified",
    "verification_mode",
    "exported_at",
    "integrity",
    "source_events",
    "continuity_state"
  ],
  "properties": {
    "protocol": {
      "const": "clista"
    },
    "packet_type": {
      "const": "continuity"
    },
    "protocol_version": {
      "const": "0.7.0"
    },
    "schema_version": {
      "const": "clista.continuity.packet.v0"
    },
    "clista_protocol_version": {
      "const": "clista.protocol.v0"
    },
    "source_thread_id": {
      "$ref": "#/$defs/id"
    },
    "event_log_hash": {
      "$ref": "#/$defs/hash"
    },
    "projection_hash": {
      "$ref": "#/$defs/hash"
    },
    "state_hash": {
      "$ref": "#/$defs/hash"
    },
    "integrity_verified": {
      "const": true
    },
    "strict_integrity_verified": {
      "type": "boolean"
    },
    "verification_mode": {
      "enum": [
        "strict",
        "compatibility"
      ]
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "integrity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "valid",
        "eventCount",
        "headHash"
      ],
      "properties": {
        "schema": {
          "const": "clista.integrity.v0"
        },
        "valid": {
          "const": true
        },
        "eventCount": {
          "type": "integer",
          "minimum": 1
        },
        "headHash": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "source_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "continuity_state": {
      "$ref": "#/$defs/continuityState"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{3}_[a-zA-Z0-9][a-zA-Z0-9_-]*$"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "continuityState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission",
        "continuity_claim",
        "source_thread_id",
        "current_question",
        "current_request",
        "current_decision",
        "assumptions",
        "active_assumptions",
        "claims",
        "accepted_claims",
        "open_objections",
        "governance_status",
        "outcome_state",
        "fork_lineage",
        "merge_state",
        "integrity_state",
        "status",
        "next_action"
      ],
      "properties": {
        "mission": {
          "const": "Conversation is input. Reasoning state is output."
        },
        "continuity_claim": {
          "const": "Projected reasoning state is continuity."
        },
        "source_thread_id": {
          "$ref": "#/$defs/id"
        },
        "current_question": {
          "type": "string"
        },
        "current_request": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "current_decision": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "assumptions": {
          "$ref": "#/$defs/objectArray"
        },
        "active_assumptions": {
          "$ref": "#/$defs/objectArray"
        },
        "claims": {
          "$ref": "#/$defs/objectArray"
        },
        "accepted_claims": {
          "$ref": "#/$defs/objectArray"
        },
        "open_objections": {
          "$ref": "#/$defs/objectArray"
        },
        "governance_status": {
          "type": "object",
          "additionalProperties": true
        },
        "outcome_state": {
          "type": "object",
          "additionalProperties": true
        },
        "fork_lineage": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "merge_state": {
          "type": "object",
          "additionalProperties": true
        },
        "integrity_state": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "event_count",
            "event_log_hash",
            "head_hash",
            "integrity_verified",
            "strict_integrity_verified",
            "verification_mode"
          ],
          "properties": {
            "event_count": {
              "type": "integer",
              "minimum": 1
            },
            "event_log_hash": {
              "$ref": "#/$defs/hash"
            },
            "head_hash": {
              "$ref": "#/$defs/hash"
            },
            "integrity_verified": {
              "const": true
            },
            "strict_integrity_verified": {
              "type": "boolean"
            },
            "verification_mode": {
              "enum": [
                "strict",
                "compatibility"
              ]
            }
          }
        },
        "status": {
          "type": "string"
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "objectArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
