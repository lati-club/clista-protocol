          "$ref": "#/$defs/id"
        },
        "targetThreadId": {
          "$ref": "#/$defs/id"
        },
        "openedBy": {
          "$ref": "#/$defs/id"
        },
        "openedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "review",
            "changes_requested",
            "rejected",
            "merged"
          ]
        },
        "proposedAssumptionIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "proposedEvidenceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "proposedClaimIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "proposedObjectionIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
