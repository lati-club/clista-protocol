        "threadId": {
          "$ref": "#/$defs/id"
        },
        "decisionRecordId": {
          "$ref": "#/$defs/id"
        },
        "participantId": {
          "$ref": "#/$defs/id"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "objectionIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "filedAt": {
