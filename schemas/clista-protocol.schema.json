      }
    },
    "mergeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mergeRequestId",
        "object",
        "threadId",
        "sourceForkThreadId",
        "targetThreadId",
        "openedBy",
        "openedAt",
