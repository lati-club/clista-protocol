{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clista.ai/schemas/v0/claim.json",
  "title": "Claim",
  "description": "An assertion.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "object_type": { "type": "string", "const": "claim" },
    "thread_id": { "type": "string" },
    "author_participant_id": { "type": "string" },
    "content": { "type": "string" },
    "claim_type": { "type": "string", "enum": ["factual", "normative", "predictive", "interpretive"] },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "confidence_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id", "object_type", "thread_id", "author_participant_id", "content", "claim_type", "created_at"
  ],
  "additionalProperties": false
}